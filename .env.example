# ─── Groq (AI Analysis) ───────────────────────────────────────────────────────
# Daftar gratis di console.groq.com → Create API Key
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Appwrite (Auth + Cloud Sync) ────────────────────────────────────────────
# Buat project di cloud.appwrite.io → gratis s/d 75k MAU
# Lalu buat Database + Collection (lihat README untuk setup lengkap)
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_APPWRITE_DATABASE_ID=financial_db
NEXT_PUBLIC_APPWRITE_COLLECTION_ID=user_data
